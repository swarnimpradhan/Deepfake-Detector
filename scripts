import os
import cv2
import numpy as np
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Conv2D, MaxPooling2D, Flatten, Dense

X, y = [], []

for label, value in [("real", 0), ("fake", 1)]:
    folder = f"dataset/frames/{label}"
    for video in os.listdir(folder):
        for img in os.listdir(f"{folder}/{video}")[:50]:
            img_path = f"{folder}/{video}/{img}"
            image = cv2.imread(img_path)
            X.append(image)
            y.append(value)

X = np.array(X) / 255.0
y = np.array(y)

model = Sequential([
    Conv2D(32, (3,3), activation="relu", input_shape=(128,128,3)),
    MaxPooling2D(),
    Flatten(),
    Dense(1, activation="sigmoid")
])

model.compile(optimizer="adam", loss="binary_crossentropy", metrics=["accuracy"])
model.fit(X, y, epochs=5, batch_size=16)

model.save("video_model.h5")
print("Video model saved")

from moviepy import VideoFileClip
import os

def extract_audio(video_path, output_audio):
    clip = VideoFileClip(video_path)

    # ✅ CHECK IF AUDIO EXISTS
    if clip.audio is not None:
        clip.audio.write_audiofile(output_audio, verbose=False, logger=None)
    else:
        print(f"[SKIPPED] No audio in: {video_path}")

    clip.close()


for label in ["real", "fake"]:
    video_dir = f"dataset/{label}"
    audio_dir = f"dataset/audio/{label}"
    os.makedirs(audio_dir, exist_ok=True)

    for video in os.listdir(video_dir):
        if video.endswith(".mp4"):
            extract_audio(
                f"{video_dir}/{video}",
                f"{audio_dir}/{video.split('.')[0]}.wav"
            )

import cv2
import os

def extract_frames(video_path, output_folder):
    cap = cv2.VideoCapture(video_path)
    os.makedirs(output_folder, exist_ok=True)
    count = 0

    while True:
        ret, frame = cap.read()
        if not ret:
            break

        frame = cv2.resize(frame, (128, 128))
        cv2.imwrite(f"{output_folder}/frame_{count}.jpg", frame)
        count += 1

    cap.release()

# Process all videos
for label in ["real", "fake"]:
    video_dir = f"dataset/{label}"
    for video in os.listdir(video_dir):
        extract_frames(
            f"{video_dir}/{video}",
            f"dataset/frames/{label}/{video.split('.')[0]}"
        )

print("Frames extracted successfully")
